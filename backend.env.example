# Server
NODE_ENV=development
PORT=3000

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,exp://192.168.1.37:8082,farmy://oauth-callback

# Cookie
COOKIE_SAME_SITE=strict

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database_name>?appName=<app_name>

# JWT
JWT_SECRET=<access_secret>
JWT_REFRESH_SECRET=<refresh_secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Cloudflare R2
R2_ACCOUNT_ID=<account_id>
R2_ACCESS_KEY_ID=<access_key_id>
R2_SECRET_ACCESS_KEY=<secret_access_key>
R2_BUCKET_NAME=<bucket_name>
R2_PUBLIC_URL=<public_url>

# Gemini
GEMINI_API_KEY=<gemini_api_key>
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_VISION_MODEL=gemini-3.1-flash-lite
PLANT_SCAN_MODEL=gemini-3.1-flash-lite

# Supabase / Postgres
PG_CONNECTION_STRING=postgresql://<user>:<password>@<host>:<port>/<database>
SUPABASE_DB_URL=postgresql://<user>:<password>@<host>:<port>/<database>
TEST_MONGO_URI=mongodb://127.0.0.1:27017/farmy
TEST_SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<gmail_address>
SMTP_PASS=<gmail_app_password>

# Google OAuth
GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173
# Mobile OAuth must prefer a trusted redirect_uri/state from the app when present.
# Expo Go callback example: exp://192.168.1.37:8082/--/oauth-callback
# Standalone/dev build callback example: farmy://oauth-callback
