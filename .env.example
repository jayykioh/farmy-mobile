# Web: localhost works when running `npm run web`
EXPO_PUBLIC_API_URL_WEB=http://localhost:3000/api/v1
# Android emulator: use 10.0.2.2 to reach the host machine
EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2:3000/api/v1
# Android physical device: replace android URL with your computer LAN IP, for example:
# EXPO_PUBLIC_API_URL_ANDROID=http://192.168.1.37:3000/api/v1
# iOS simulator: localhost works when backend runs on the same machine
EXPO_PUBLIC_API_URL_IOS=http://localhost:3000/api/v1
# Generic fallback
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
